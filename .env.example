# ============================================
# Rifa Solidaria — Environment Variables
# ============================================
# Copy this file to .env.local and fill in the values
# cp .env.example .env.local

# ============================================
# Upstash Redis (Vercel Marketplace)
# ============================================
# Get these from: Vercel Dashboard → Storage → your Redis store → Variables
# Or from Upstash Console: https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# ============================================
# Admin Panel
# ============================================
# Secret token for admin/seller access
# Use: /admin?token=YOUR_ADMIN_TOKEN
# Generate a strong random string (min 16 chars)
ADMIN_TOKEN=change-me-to-a-strong-secret-token

# ============================================
# Raffle Configuration
# ============================================
# Number of rows in the grid (default: 10, for 00-99)
NEXT_PUBLIC_GRID_ROWS=10

# Reservation timeout in hours (numbers return to available after this)
NEXT_PUBLIC_RESERVE_TIMEOUT_HOURS=24
