{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "preprocess:hero": "node scripts/preprocess-hero.mjs",
    "dev": "node scripts/preprocess-hero.mjs && next dev",
    "build": "node scripts/preprocess-hero.mjs && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "seed:config": "dotenv -e .env.local -- tsx scripts/seed.ts",
    "seed:reset": "dotenv -e .env.local -- tsx scripts/seed.ts --reset",
    "seed:backup": "dotenv -e .env.local -- tsx scripts/backup.ts",
    "seed:restore": "dotenv -e .env.local -- tsx scripts/restore.ts"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@resvg/resvg-js-linux-arm64-gnu": "^2.6.2",
    "@resvg/resvg-js-linux-x64-gnu": "^2.6.2",
    "@upstash/redis": "^1.38.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "satori": "^0.26.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@img/sharp-linux-x64": "^0.35.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "sharp": "^0.35.1",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
